# Use the project URL, not the REST endpoint. Example: https://project-ref.supabase.co
PUBLIC_SUPABASE_URL=
# Use the anon public key only. Never use the service_role key in this app.
PUBLIC_SUPABASE_ANON_KEY=
# Optional one-user username alias. The app can turn this username into the Supabase Auth email below.
PUBLIC_SUPABASE_AUTH_USERNAME=aniketlovesalejandra
PUBLIC_SUPABASE_AUTH_EMAIL=ianiket23@gmail.com
# Fallback username domain. If no alias matches, the app turns "aniket" into "aniket@canvas.local".
PUBLIC_SUPABASE_USERNAME_DOMAIN=canvas.local
PUBLIC_SPOTIFY_EMBED_URL=https://open.spotify.com/embed/playlist/37i9dQZF1DX50QitC6Oqtn?utm_source=generator&theme=0
